rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // All user data lives under users/{uid}/**
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);

      match /notes/{docId} {
        allow read, delete: if isAuth() && isOwner(uid);
        allow create, update: if isAuth() && isOwner(uid)
          && request.resource.data.keys().hasAll(['title', 'content', 'createdAt'])
          && request.resource.data.title is string
          && request.resource.data.content is string;
      }

      match /tasks/{docId} {
        allow read, delete: if isAuth() && isOwner(uid);
        allow create, update: if isAuth() && isOwner(uid)
          && request.resource.data.keys().hasAll(['title', 'status', 'priority', 'createdAt'])
          && request.resource.data.title is string;
      }

      match /recordings/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /calendarEvents/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /shoppingLists/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /recipes/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /expenses/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /contacts/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /followUps/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /meetingSummaries/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /bookingLinks/{docId} {
        allow read: if true; // public — booking pages are unauthenticated
        allow write: if isAuth() && isOwner(uid);
      }

      match /bookings/{docId} {
        allow read: if true; // public — needed to check slot availability
        allow create: if true // public — visitors create their own bookings
          && request.resource.data.keys().hasAll(['start', 'end', 'name', 'email'])
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 100
          && request.resource.data.email is string
          && request.resource.data.email.size() <= 200;
        allow update, delete: if isAuth() && isOwner(uid);
      }

      match /availability/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /memories/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /timelineEvents/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /chatHistory/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /suggestedItems/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /mapSessions/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /rawTranscriptions/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /aiProcessingLogs/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /dismissedActions/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /workouts/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      match /nutrition/{docId} {
        allow read, write: if isAuth() && isOwner(uid);
      }
    }

    // Invites: anyone can read; admin can create/delete;
    // any authenticated user can mark their own claimed invite as used
    match /invites/{inviteId} {
      allow read: if true;
      allow create, delete: if isAuth() && request.auth.uid == "K4tyhRdHdvQ6ZfD8cN807VxbGYJ3";
      allow update: if isAuth() && (
        request.auth.uid == "K4tyhRdHdvQ6ZfD8cN807VxbGYJ3" ||
        (resource.data.used == false && request.resource.data.used == true)
      );
    }

    // Slug index: public read for booking pages, only the slug owner can write
    match /slugIndex/{slugId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Mirror rooms — WebRTC signaling for screen casting.
    // Authenticated (including anonymous) users can create and join rooms.
    // Anonymous auth is used on the TV side, signed-in users cast from the app.
    match /mirrorRooms/{roomId} {
      allow read, write: if isAuth();

      match /senderCandidates/{id} {
        allow read, write: if isAuth();
      }
      match /receiverCandidates/{id} {
        allow read, write: if isAuth();
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
