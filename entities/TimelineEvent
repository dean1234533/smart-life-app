        "meeting",
        "conversation",
        "decision",
        "task",
        "promise",
        "milestone"
      ],
      "description": "Type of timeline event"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "event_date": {
      "type": "string",
      "format": "date-time"
    },
    "related_people": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_type": {
      "type": "string",
      "enum": [
        "note",
        "voice",
        "manual",
        "ai_generated"
      ]
