{
  "name": "Booking",
  "type": "object",
  "properties": {
    "booker_name": {
      "type": "string"
    },
    "booker_email": {
      "type": "string"
    },
    "meeting_reason": {
      "type": "string"
    },
    "proposed_date": {
      "type": "string",
      "format": "date-time"
    },
    "duration_minutes": {
      "type": "number",
      "default": 30
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled"
      ],
      "default": "pending"
    },
    "calendar_event_id": {
      "type": "string"
    },
    "booking_owner_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "booker_name",
    "booker_email",
    "proposed_date"
  ]
}