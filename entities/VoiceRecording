    "related_people": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "recording",
        "processing",
        "completed",
        "error"
      ],
      "default": "recording"
    }
  },
  "required": [
    "title"
  ]
}